# --- Core ---
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Postgres ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=lmx_os
POSTGRES_USER=lmx
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql+asyncpg://lmx:change_me@localhost:5432/lmx_os

# --- Redis (fleet state, hold queue, <50ms read target) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# --- Batch-hold queue ---
BATCH_HOLD_CLUSTER_RADIUS_MILES=0.8
OPTIMIZER_CYCLE_BUDGET_SECONDS=5.0

# --- Third-party (Phase 1 stubs until credentials are provisioned) ---
# Route Optimization API auth is via Application Default Credentials, not
# an API key - set GOOGLE_APPLICATION_CREDENTIALS to a service account
# JSON key (roles/cloudoptimization.user) and GOOGLE_CLOUD_PROJECT_ID to
# the project that key belongs to.
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_MAPS_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- POS/DMS: Epicor (Phase 1 priority integration) ---
EPICOR_BASE_URL=
EPICOR_API_KEY=

# --- Orchestrator dashboard (dashboard/) ---
# Comma-separated list of origins allowed to call this API cross-origin.
DASHBOARD_CORS_ORIGINS=http://localhost:5173

# --- API auth (interim stopgap - see docs/ARCHITECTURE.md item 0) ---
# Unset = every endpoint stays open, same as before this existed. Set to
# require this value in an X-API-Key header on every request except
# /health and the API docs. If the dashboard needs to reach this API,
# also set dashboard/.env's VITE_API_SHARED_SECRET to the same value.
API_SHARED_SECRET=

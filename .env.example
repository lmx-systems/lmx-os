# --- Core ---
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Postgres ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=lmx_os
POSTGRES_USER=lmx
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql+asyncpg://lmx:change_me@localhost:5432/lmx_os

# --- Redis (fleet state, hold queue, <50ms read target) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# --- Batch-hold queue ---
BATCH_HOLD_CLUSTER_RADIUS_MILES=0.8
OPTIMIZER_CYCLE_BUDGET_SECONDS=5.0

# --- Third-party (Phase 1 stubs until credentials are provisioned) ---
# Route Optimization API auth is via Application Default Credentials, not
# an API key - set GOOGLE_APPLICATION_CREDENTIALS to a service account
# JSON key (roles/cloudoptimization.user) and GOOGLE_CLOUD_PROJECT_ID to
# the project that key belongs to.
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_MAPS_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- POS/DMS: Epicor (Phase 1 priority integration) ---
EPICOR_BASE_URL=
EPICOR_API_KEY=

# --- Orchestrator dashboard (dashboard/) ---
# Comma-separated list of origins allowed to call this API cross-origin.
DASHBOARD_CORS_ORIGINS=http://localhost:5173

# --- Ops dashboard auth (app/ops_auth/, docs/ROADMAP.md S1) ---
# Signs/verifies the JWT issued on POST /ops/auth/login. Must be distinct
# from CLIENT_JWT_SECRET/DRIVER_JWT_SECRET outside development (see
# app/config.py's assert_jwt_secrets_are_distinct) - the default is an
# obviously-fake dev value, deliberately loud rather than
# silently "secure-looking" in an environment nobody configured it for.
# Bootstrap the first account with:
#   python -m scripts.create_ops_user --email you@lmxit.com --password "..." --name "Your Name"
OPS_JWT_SECRET=dev-only-insecure-secret-change-in-production

# --- Observability (app/logging_config.py) ---
# Unset = sentry_sdk.init() is never called - error tracking is a no-op,
# same as every other unconfigured third-party credential in this file.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0

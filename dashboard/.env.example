VITE_API_BASE_URL=http://localhost:8000

# No login credential to configure here - real per-account ops auth
# (app/ops_auth/, docs/ROADMAP.md S1) is a runtime login (POST
# /ops/auth/login), not a build-time secret. Bootstrap the first account
# with:
#   python -m scripts.create_ops_user --email you@lmxit.com --password "..." --name "Your Name"

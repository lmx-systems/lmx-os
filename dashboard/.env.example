VITE_API_BASE_URL=http://localhost:8000

# Must match the backend's API_SHARED_SECRET (see .env.example at the repo
# root) if that's set. Baked into the built JS bundle at build time like
# VITE_API_BASE_URL - visible to anyone who opens dev tools, so this is
# only appropriate for an internal tool behind its own access control, not
# a substitute for real auth. See docs/ARCHITECTURE.md item 0.
VITE_API_SHARED_SECRET=

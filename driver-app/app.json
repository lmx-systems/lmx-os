{
  "expo": {
    "name": "LMX Driver",
    "slug": "lmx-driver-app",
    "scheme": "lmxdriver",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0c0c0b"
    },
    "notification": {
      "icon": "./assets/notification-icon.png",
      "color": "#0a6644"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lmx.driver",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Unlock LMX Driver with Face ID instead of re-entering a verification code every shift.",
        "NSCameraUsageDescription": "LMX Driver uses the camera to scan parcel barcodes and capture proof-of-delivery photos."
      }
    },
    "android": {
      "package": "com.lmx.driver",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0c0c0b"
      },
      "permissions": [
        "CAMERA"
      ]
    },
    "extra": {
      "apiBaseUrl": "http://localhost:8000"
    },
    "plugins": [
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#0a6644"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "LMX Driver uses the camera to scan parcel barcodes and capture proof-of-delivery photos."
        }
      ]
    ]
  }
}
